# Environment Variables for Netlify Deployment
# Copy this file to .env.local for local development
# Set these variables in Netlify Dashboard > Site Settings > Environment Variables

# ===========================================
# AI & CHAT SERVICES
# ===========================================

# Gemini AI API Key (for AI chatbot responses)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (alternative AI service)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# EMAIL SERVICES
# ===========================================

# Resend API Key (for email notifications)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# ===========================================
# VOICE & REAL-TIME SERVICES
# ===========================================

# LiveKit API Key (for voice interactions)
# Get from: https://cloud.livekit.io/
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here
LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# ===========================================
# BLOCKCHAIN & SMART CONTRACTS
# ===========================================

# Private key for smart contract deployment (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# RPC URLs for different networks
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
POLYGON_RPC_URL=https://polygon-rpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# API Keys for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key
BSCSCAN_API_KEY=your_bscscan_api_key

# ===========================================
# HEALTH MONITORING & INTEGRATIONS
# ===========================================

# Google Fit API (for wearable data)
GOOGLE_FIT_CLIENT_ID=your_google_fit_client_id
GOOGLE_FIT_CLIENT_SECRET=your_google_fit_client_secret

# WebSocket server configuration
WEBSOCKET_PORT=3001

# ===========================================
# NETLIFY SPECIFIC
# ===========================================

# Netlify build settings
NEXT_PUBLIC_SITE_URL=https://your-site-name.netlify.app
NEXT_PUBLIC_API_URL=https://your-site-name.netlify.app/api

# ===========================================
# DEVELOPMENT ONLY (don't set in production)
# ===========================================

# Local development database
DATABASE_URL=postgresql://user:password@localhost:5432/sanjeevan

# Local development settings
NODE_ENV=development
